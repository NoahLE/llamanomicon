{
  "name": "llamanomicon",
  "private": true,
  "version": "0.0.1",
  "author": "NoahLE",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "type-check": "tsc -b --noEmit",
    "format-check": "prettier . --check",
    "format-fix": "prettier . --write --list-different --cache --ignore-unknown",
    "lint-all": "pn lint-fix && pn type-check && pn format-fix && pn knip",
    "test": "vitest run",
    "test-watch": "vitest watch",
    "test-e2e": "playwright test",
    "test-e2e-ui": "playwright test --ui",
    "test-e2e-update": "playwright test --update-snapshots",
    "test-all": "pn test && pn test-e2e",
    "preview": "vite preview",
    "commit": "cz",
    "knip": "knip --fix --cache --format"
  },
  "dependencies": {
    "@heroui/react": "^3.0.5",
    "@heroui/styles": "^3.0.5",
    "immer": "^11.1.8",
    "intro.js": "^8.3.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "@rollup/plugin-terser": "^1.0.0",
    "serialize-javascript": "^7.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-dom": "^5.8.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-react-x": "^5.8.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
